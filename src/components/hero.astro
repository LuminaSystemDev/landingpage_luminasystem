---
// --- SECCION DE LOGICA (JS) ---
import {getImage} from 'astro:assets';
import heroImage from '../assets/img_hero_01.jpg';

---
<section class="hero" id="hero" style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url(${heroImage.src});`}>
    <div class="hero-content">
        <h1 class="name">LuminaSystem</h1>
        <h2 class="text-hero">Desarrollo de aplicaciones Web, Mobiles y Escritorio Freelancer</h2>
        <button class="action"><a class="ir-contact-form" href="#contact-form-section">Automatiza Tu Negocio Ya!!!</a></button>
    </div>
</section>

<style>
    /* --- SECCIÓN DE ESTILOS (CSS) --- */
    *{
        box-sizing: border-box;
    }
    
    .hero{
        height: 70vh;
        width: 100%;

        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
        position: relative;
        
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .hero-content {
        text-align: center;
        font-size: 24px;
        color: white;
    }

    .name, .text-hero {
        text-shadow: 0px 4px 10px rgba(0, 0, 0, 0.5);
    }

    .action {
        padding: 0;
        border: none;
        border-radius: 5px;
        background-color: white;
        box-shadow: 0px 4px 10px rgb(0, 0, 0, 0.3);
        font-size: 18px;
        cursor: pointer;
    }

    .action:hover {
        background-color: rgb(240, 116, 116);
    }

    .ir-contact-form {
        display: block;
        padding: 15px 20px;
        width: 100%;
        height: 100%;
        color: black;
        text-decoration: none;
    }

    .ir-contact-form:hover {
        color: white;
    }

</style>