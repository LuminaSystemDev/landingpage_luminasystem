---
// --- SECCION DE LOGICA (JS) ---

// Leer si el parámetro "enviado" existe en la URL
const mostrado = Astro.url.searchParams.get('enviado') === 'true';
---

<section class="contact-form-section" id="contact-form-section">
    <div class="container-form">
        <h2>Formulario de Contacto</h2>
        <p>Ingresa tus datos de contacto junto con los detalles del servicio de desarrollo o automatizacion solicitado y nos pondremos en contacto contigo.</p>
        <form method="POST" class="contact-form">
            <div class="form-group">
                <label for="name">Nombre Completo</label>
                <input type="text" id="name" name="name" placeholder="Ej. TecnoShop.CA" required />
            </div>

            <div class="form-group">
                <label for="email">Correo</label>
                <input type="email" id="email" name="email" placeholder="Ej. tecnoshop@gamil.com" required />
            </div>
               
            <div class="form-group">
                <label for="phone">Telefono</label>
                <input type="text" id="phone" name="phone" placeholder="Ej. +58 4245550555" />
            </div>
               
            <div class="form-group">
                <label for="affair">Asunto</label>
                <input type="text" id="affair" name="affair" placeholder="Ej. Desarrollo de un sistema para la gestión de inventario" required />
            </div>
            
            <div class="form-group">
                <label for="details">Detalles</label>
                <textarea id="details" name="details" placeholder="Ej. Desarrollar un sistema avanzado para gestionar el stock de los productos en el inventario" required></textarea>
            </div>

            <button type="submit" id="btn-submit">Enviar</button>

            {mostrado && (
                <div class="alert-success" id="alert-success">
                    <p class="success-message">✅ ¡Gracias! Hemos recibido tus datos correctamente.</p>
                </div>
            )}
        </form>
    </div>
</section>

<style>
    /* --- SECCIÓN DE ESTILOS (CSS) --- */
    * {
        box-sizing: border-box;
    }

    h2 {
        display: inline-block;
        border-bottom: 3px solid rgb(240, 116, 116);
        color: white;
        padding-bottom: 8px;
        font-weight: bold;
    }

    p {
        color: white;
        font-size: 20px;
    }

    .contact-form-section {
        padding: 1rem 5%;
        justify-content: center;
        background-color: rgb(20, 20, 20);;
    }

    .container-form {
        background-color: rgb(20, 20, 20);
        text-align: start;
    }

    .contact-form {
        padding: 2rem;
        border-radius: 5px;
        text-align: left;
        background-color: rgb(20, 20, 20);
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    label {
        color: white;
        font-size: 20px;
        font-weight: 600;
        display: block;
        margin-bottom: 0.5rem;
    }

    input, textarea {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 5px;
        background-color: #252525;
        color: white;
        font-size: 16px;
    }

    #btn-submit {
        width: 200px;
        border-radius: 5px;
        padding: 15px;
        border: none;
        background-color: rgb(241, 75, 75);
        color: white;
        box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.3);
        font-size: 16px;
        cursor: pointer;
    }

    #btn-submit:hover {
        background-color: white;
        color: rgb(224, 57, 57);
    }

    @media (max-width: 500px){

        input, textarea {
            width: 100%;
        }

        #btn-submit {
            width: 100%;
        }
    }

</style>
